<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IvanConnections_Travel.MainPage"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:sensors="clr-namespace:Microsoft.Maui.Devices.Sensors;assembly=Microsoft.Maui.Essentials"
             xmlns:xct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:IvanConnections_Travel.Controls"
             xmlns:converters="clr-namespace:IvanConnections_Travel.Converters"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             x:Name="this"
             xmlns:vm="clr-namespace:IvanConnections_Travel.ViewModels"
             x:DataType="vm:MainPageViewModel">
    <ContentPage.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <Style TargetType="Button" x:Key="FilterButtonStyle">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="{StaticResource OffBlackBorder}" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </ContentPage.Resources>
    <ContentPage.Behaviors>
        <xct:EventToCommandBehavior EventName="Appearing"
                                    BindingContext="{Binding Path=BindingContext, Source={x:Reference this}}"
                                    Command="{Binding AppearingCommand}" />
        <xct:EventToCommandBehavior EventName="Disappearing"
                                    BindingContext="{Binding Path=BindingContext, Source={x:Reference this}}"
                                    Command="{Binding DisappearingCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <local:CustomMauiMap x:Name="MyMap"
                             IsShowingUser="True"
                             IsTrafficEnabled="{Binding IsTrafficEnabled}"
                             MoveToLocation="{Binding MapCenterLocation}"
                             MapBearing="{Binding MapBearing, Mode=TwoWay}"
                             Vehicles="{Binding Pins}"
                             Shapes="{Binding Shapes}"
                             Stops="{Binding AllStops}"
                             ShowStops="{Binding ShowStopsOnMap}"
                             MarkerClickCommand="{Binding MarkerClickedCommand}"
                             MapClickCommand="{Binding MapClickedCommand}">
        </local:CustomMauiMap>

        <Grid ColumnDefinitions="*, Auto, Auto"
              RowDefinitions="Auto, Auto, *">
            <Border VerticalOptions="Center"
                    Margin="5,15,5,10"
                    StrokeThickness="1"
                    Stroke="{StaticResource OffBlackBorder}"
                    Grid.Column="0"
                    StrokeShape="RoundRectangle 25"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                    Padding="5,0,5,0">
                <Grid
                    ColumnDefinitions="Auto, *">
                    <Button
                        Grid.Column="0"
                        Clicked="OnMenuClicked"
                        HeightRequest="25"
                        WidthRequest="25"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialSymbolsRounded"
                                             Glyph="&#xe5d2;"
                                             Size="30"
                                             Color="{StaticResource PrimaryDarkText}" />
                        </Button.ImageSource>
                        </Button>
                    <local:FancySearchBar Grid.Column="1"
                                          BorderThickness="0"
                                          BackgroundColor="Transparent"
                                          VerticalOptions="Center"
                                          Placeholder="Caută o rută"
                                          IsEnabled="{Binding IsTracking, Converter={xct:InvertedBoolConverter}}"
                                          Opacity="{Binding IsTracking, Converter={StaticResource BoolToOpacityConverter}}"
                                          Text="{Binding SearchText}" />
                    <BoxView BackgroundColor="Transparent"
                             Grid.Column="1"
                             IsVisible="{Binding IsTracking}">
                        <BoxView.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowSearchDisabledToastCommand}" />
                        </BoxView.GestureRecognizers>
                    </BoxView>
                </Grid>
            </Border>
                    <Button
                        Command="{Binding ToggleShowStopsCommand}"
                        HeightRequest="50"
                        WidthRequest="50"
                        Margin="5,15,5,10"
                        CornerRadius="30"
                        Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                        BorderColor="{StaticResource OffBlackBorder}"
                        BorderWidth="1">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialSymbolsRounded"
                                             Glyph="&#xe55f;"
                                             Size="30"
                                             Color="{StaticResource PrimaryDarkText}" />
                        </Button.ImageSource>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding ShowStopsOnMap}"
                                         Value="True">
                                <Setter Property="BackgroundColor"
                                        Value="#2196F3" />
                            </DataTrigger>

                        </Button.Triggers>
                    </Button>
                    <Button
                        Command="{Binding ToggleTrafficCommand}"
                        HeightRequest="50"
                        WidthRequest="50"
                        Margin="5,15,5,10"
                        CornerRadius="30"
                        Grid.Column="2"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                        BorderColor="{StaticResource OffBlackBorder}"
                        BorderWidth="1">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialSymbolsRounded"
                                             Glyph="&#xe565;"
                                             Size="30"
                                             Color="{StaticResource PrimaryDarkText}" />
                        </Button.ImageSource>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsTrafficEnabled}"
                                         Value="True">
                                <Setter Property="BackgroundColor"
                                        Value="#2196F3" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
            <Border HorizontalOptions="Center"
                    Grid.ColumnSpan="3"
                    Grid.Row="1"
                    VerticalOptions="Start"
                    Margin="10,0,10,10"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 25"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                    Opacity="0.8"
                    IsVisible="{Binding IsTracking}"
                    Padding="10">
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="5,5"
                            Radius="10"
                            Opacity="0.3" />
                </Border.Shadow>
                <Label>
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Urmăriți vehiculul "></Span>
                            <Span Text="{Binding TrackedVehicle.Id}"></Span>
                            <Span Text=", ruta "></Span>
                            <Span Text="{Binding TrackedVehicle.RouteShortName}"></Span>
                            <Span Text=". "></Span>
                            <Span Text="Nu mai urmări."
                                  TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding StopTrackingCommand}" />
                                </Span.GestureRecognizers>
                            </Span>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Border>

            <xct:Expander Grid.Row="1"
                          Grid.ColumnSpan="3"
                          VerticalOptions="Start"
                          Margin="10,0,10,10"
                          x:Name="FilterExpander"
                          IsExpanded="False"
                          ExpandedChanged="OnFilterExpanderExpandedChanged">
                <xct:Expander.Header>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource OffBlackBorder}"
                            StrokeShape="RoundRectangle 25"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="15,10"
                            HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Opțiuni filtrare"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                            <Image Source="{FontImageSource FontFamily=MaterialSymbolsRounded, Glyph=&#xe5cf;, Color={AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}, Size=20}"
                                   x:Name="FilterIcon" />
                        </HorizontalStackLayout>
                    </Border>
                </xct:Expander.Header>
                <xct:Expander.Content>
                    <Border StrokeThickness="1"
                            x:Name="FilterExpanderContent"
                            Opacity="0"
                            TranslationY="-10"
                            Stroke="{StaticResource OffBlackBorder}"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="15"
                            Margin="0,5,0,0"
                            HorizontalOptions="Center">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Direcție (numai pentru ruta selectată):" 
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center">
                                <Button Text="Tur"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Command="{Binding SetShapeFilterCommand}"
                                        CommandParameter="_0"
                                        WidthRequest="100"
                                        CornerRadius="15">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding ShapeFilter}"
                                                     Value="_0">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="BorderWidth" Value="0" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Text="Retur"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Command="{Binding SetShapeFilterCommand}"
                                        CommandParameter="_1"
                                        WidthRequest="100"
                                        CornerRadius="15">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding ShapeFilter}"
                                                     Value="_1">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="BorderWidth" Value="0" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </HorizontalStackLayout>

                            <Label Text="Tip vehicul:"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center">
                                <Button Text="Autobuz"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Command="{Binding SetVehicleTypeFilterCommand}"
                                        CommandParameter="Autobuz"
                                        WidthRequest="85"
                                        CornerRadius="15">
                                     <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding VehicleTypeFilter}"
                                                     Value="Bus">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="BorderWidth" Value="0" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Text="Tramvai"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Command="{Binding SetVehicleTypeFilterCommand}"
                                        CommandParameter="tramvai"
                                        WidthRequest="85"
                                        CornerRadius="15">
                                     <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding VehicleTypeFilter}"
                                                     Value="Tram">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="BorderWidth" Value="0" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Text="Toate"
                                        Style="{StaticResource FilterButtonStyle}"
                                        Command="{Binding SetVehicleTypeFilterCommand}"
                                        CommandParameter="toate"
                                        WidthRequest="85"
                                        CornerRadius="15">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding VehicleTypeFilter}"
                                                     Value="{x:Null}">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="BorderWidth" Value="0" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </xct:Expander.Content>
            </xct:Expander>
        </Grid>
        <Button VerticalOptions="End"
                HorizontalOptions="End"
                Margin="20,20,20,85"
                WidthRequest="50"
                BorderColor="{StaticResource OffBlackBorder}"
                BorderWidth="1"
                BackgroundColor="{StaticResource OffBlack}"
                HeightRequest="50"
                CornerRadius="30"
                Command="{Binding ResetBearingCommand}"
                Rotation="{Binding CompassRotation}"
                IsVisible="{Binding IsCompassVisible}">

            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialSymbolsRounded"
                                 Glyph="&#xf1e0;"
                                 Color="{StaticResource White}" />
            </Button.ImageSource>
            <Button.Shadow>
                <Shadow Brush="Black"
                        Offset="5,5"
                        Radius="10"
                        Opacity="0.5" />
            </Button.Shadow>

        </Button>
        <Button VerticalOptions="End"
                HorizontalOptions="End"
                Margin="20"
                WidthRequest="50"
                BorderColor="{StaticResource OffBlackBorder}"
                BorderWidth="1"
                BackgroundColor="{StaticResource OffBlack}"
                HeightRequest="50"
                CornerRadius="30"
                Command="{Binding CenterOnUserLocationCommand}">

            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialSymbolsRounded"
                                 Glyph="&#xe1b3;"
                                 Color="{StaticResource White}" />
            </Button.ImageSource>
            <Button.Shadow>
                <Shadow Brush="Black"
                        Offset="5,5"
                        Radius="10"
                        Opacity="0.5" />
            </Button.Shadow>

        </Button>
        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           VerticalOptions="End"
                           HorizontalOptions="Start"
                           Margin="15,20,15,15"
                           WidthRequest="10"
                           HeightRequest="10"
                           IsRunning="{Binding IsBusy}">
        </ActivityIndicator>
    </Grid>
</ContentPage>