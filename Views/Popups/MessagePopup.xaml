<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               CanBeDismissedByTappingOutsideOfPopup="False"
               Color="Transparent"
               x:Class="IvanConnections_Travel.Views.Popups.MessagePopup">

    <Border Stroke="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource OffBlackBorder}}"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
            MinimumWidthRequest="300"
            MaximumWidthRequest="340"
            Padding="24">
        <Border.Shadow>
            <Shadow Brush="Black"
                    Offset="0,4"
                    Radius="16"
                    Opacity="0.12" />
        </Border.Shadow>
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20" />
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="16">

            <!-- Icon circle -->
            <Border x:Name="IconBorder"
                    WidthRequest="68"
                    HeightRequest="68"
                    StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="34" />
                </Border.StrokeShape>
                <Label x:Name="IconLabel"
                       FontFamily="MaterialSymbolsRounded"
                       FontSize="34"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <!-- Title -->
            <Label x:Name="TitleLabel"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <!-- Message -->
            <Label x:Name="MessageLabel"
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
                   LineBreakMode="WordWrap" />

            <!-- Buttons -->
            <HorizontalStackLayout x:Name="ButtonsLayout"
                                   HorizontalOptions="Center"
                                   Spacing="12"
                                   Margin="0,8,0,0">

                <Button x:Name="SecondaryButton"
                        IsVisible="False"
                        Clicked="OnSecondaryButtonClicked"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource OffBlackBorder}}"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        CornerRadius="12"
                        MinimumWidthRequest="110"
                        HeightRequest="46"
                        FontSize="15"
                        FontAttributes="Bold" />

                <Button x:Name="PrimaryButton"
                        Clicked="OnPrimaryButtonClicked"
                        TextColor="White"
                        CornerRadius="12"
                        MinimumWidthRequest="110"
                        HeightRequest="46"
                        FontSize="15"
                        FontAttributes="Bold" />

            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
