<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="IvanConnections_Travel.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:IvanConnections_Travel"
    xmlns:converters="clr-namespace:IvanConnections_Travel.Converters"
    xmlns:views="clr-namespace:IvanConnections_Travel.Views"
    xmlns:vm="clr-namespace:IvanConnections_Travel.ViewModels"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
    Title="IvanConnections_Travel">
    <Shell.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <x:String x:Key="IconMap">&#xe55b;</x:String>
        <x:String x:Key="IconSettings">&#xe8b8;</x:String>
    </Shell.Resources>
    <Shell.FlyoutHeader>
        <Grid Padding="16,20,16,16" BackgroundColor="Transparent" RowSpacing="0" Margin="0,50,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logged-in state: avatar + display name -->
            <HorizontalStackLayout
                Grid.Row="0"
                Spacing="12"
                IsVisible="{Binding IsLoggedIn}">
                <Border
                    WidthRequest="48"
                    HeightRequest="48"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Image
                        Source="{Binding CurrentUser.AvatarUrl}"
                        Aspect="AspectFill"
                        WidthRequest="48"
                        HeightRequest="48" />
                </Border>
                <Label
                    Text="{Binding CurrentUser.DisplayName}"
                    FontSize="16"
                    FontAttributes="Bold"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </HorizontalStackLayout>

            <!-- Logged-out state: login button -->
            <Button
                Grid.Row="0"
                Text="Activează chatul!"
                Command="{Binding LoginCommand}"
                IsVisible="{Binding IsLoggedIn, Converter={StaticResource InvertedBoolConverter}}"
                HorizontalOptions="Start"
                BackgroundColor="#1976D2"
                TextColor="White"
                CornerRadius="8"
                Padding="20,8"
                FontSize="14" />

            <!-- Loading indicator -->
            <ActivityIndicator
                Grid.Row="1"
                IsRunning="{Binding IsLoggingIn}"
                IsVisible="{Binding IsLoggingIn}"
                Color="#1976D2"
                HeightRequest="20"
                Margin="0,8,0,0"
                HorizontalOptions="Start" />
        </Grid>
    </Shell.FlyoutHeader>
    <FlyoutItem Title="Hartă">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="MaterialSymbolsRounded"
                Glyph="{StaticResource IconMap}"
                Size="24"
                Color="Gray" />
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Setări">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="MaterialSymbolsRounded"
                Glyph="{StaticResource IconSettings}"
                Size="24"
                Color="Gray" />
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>
</Shell>
