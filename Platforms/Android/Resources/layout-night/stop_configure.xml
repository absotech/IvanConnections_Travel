<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:padding="16dp"
              android:background="@color/widget_bg">
    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alege o statie"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="16dp"
            android:textColor="@color/widget_title"/>
    <EditText
            android:id="@+id/stop_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cauta statii..."
            android:textColorHint="@color/widget_hint"
            android:textColor="@color/widget_title"/>
    <ListView
            android:id="@+id/stops_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@color/widget_divider"
            android:dividerHeight="1dp"/>
</LinearLayout>